# DEV ONLY — production uses OS keychain via Tauri
CLAUDE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_URL=http://localhost:11434
WHISPER_MODEL=base
WHISPER_DEVICE=auto
OUTPUT_DIR=./outputs
DATABASE_URL=sqlite:///./outputs/primeclip.db
