FFMPEG_PATH=
BUNDLE_PROFILE=lite
PRIMECLIP_DEBUG=true
YTDLP_PATH=
IMPORT_MAX_DURATION_SEC=7200
YTDLP_COOKIES_FILE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
